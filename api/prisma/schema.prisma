// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
enum Role{
  GESTOR
  OPERADOR
}

enum StatusConciliacao{
  PENDENTE
  CONCILIADO
  DIVERGENTE
  CANCELADO
}
enum Category{
  SANGRIA
  OUTRAS_ENTRADAS
  DESPESA
  DEPOSITO
}
enum Status{
  SINCRONIZADO
  PENDENTE
}
enum StatusJob{
  RUNNING 
  SUCCESS
  FAILED
}
model User {
  id Int @default(autoincrement()) @id
  login Int @unique
  password String
  name String
  role Role
  filialId Int?
  filial Filial? @relation("FiliaAndlUser",fields: [filialId],references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Movimentations{
  id Int @default(autoincrement()) @id
  idTrier Int?
  status Status @default(PENDENTE)
  category String?
  idCategoria Int?
  idContaDest Int?
  
  valueSangriaTrier Decimal? @db.Decimal(9,2)
  descrition String
  value Decimal?  @db.Decimal(9,2)
  type Category
  filialId Int
  filial Filial @relation("FiliaAndMovimentations",fields: [filialId],references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model DailyBalance {
  id        Int      @default(autoincrement()) @id
  balance   Decimal  @db.Decimal(9,2)
  filialId Int?
  filial Filial? @relation("FiliaAndDayBalancy",fields: [filialId],references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Filial{
  id Int @default(autoincrement()) @id
  name String
  user User[] @relation("FiliaAndlUser")
  idCofreTrier Int?
  idBancoDefault Int?
  idCielo String?
  idRede String?
  urlLocalTrier String?
  saldo DailyBalance[] @relation("FiliaAndDayBalancy")
  movements Movimentations[] @relation("FiliaAndMovimentations")
  balanceFisic BalanceFisic[] @relation("FiliaAndBalancyFisic")
  trierCartaoSales TrierCartaoVendas[] @relation("FilialAndTrierCartaoVendas")
  redeCartaoSales RedeVenda[] @relation("FilialAndRedeCartaoVendas")
  conciliacoes Conciliacao[]

}

model CartaoVendas{
  id Int @default(autoincrement()) @id
  dataVenda String
  timeVenda String
    valorBruto Decimal
    valorLiquido Decimal
    taxaAdministrativa Decimal
    modalidade String
    bandeira String
    estabelecimento String
    nsu String
    codigoAutorizacao String
    codigoTransacao String
}
model TrierCartaoVendas{
  id Int @default(autoincrement()) @id
  idempotencyKey String @unique
  documentoFiscal Int
  valor Decimal
  modalidade String?
  hora DateTime @db.Time(0)
  tipo String
  filialId Int
  filial Filial @relation("FilialAndTrierCartaoVendas",fields: [filialId],references: [id])
  bandeira String
  dataEmissao DateTime @db.Date
  dataVencimento DateTime? @db.Date
  dataPagamento DateTime? @db.Date
  statusConciliacao StatusConciliacao @default(PENDENTE)
  conciliacaoItens ConciliacaoItem[]

  @@index([filialId, dataEmissao,hora])
  @@index([valor, dataEmissao, hora])
}

model RedeVenda {
  id              Int      @id @default(autoincrement())
  idempotencyKey  String   @unique
  nsu             String?
  autorizacao     String?
  valor           Decimal  @db.Decimal(10,2)
  bandeira        String?
  modalidade      String?
  dataAutorizacao DateTime @db.DateTime(0)
  filialId        Int
  filial          Filial   @relation("FilialAndRedeCartaoVendas",fields: [filialId], references: [id])

  statusConciliacao StatusConciliacao @default(PENDENTE)
   conciliacaoItens ConciliacaoItem[]
   
  @@index([filialId, dataAutorizacao])
  @@index([valor, dataAutorizacao])
}
model Conciliacao {
  id          Int      @id @default(autoincrement())
  filialId    Int
  filial      Filial   @relation(fields: [filialId], references: [id])

  status      StatusConciliacao @default(CONCILIADO) // ou PENDENTE/DIVERGENTE se você quiser “propostas”
  metodo      MetodoConciliacao
  motivo      String?
  createdAt   DateTime @default(now())
  createdById Int?

  itens       ConciliacaoItem[]

  @@index([filialId, createdAt])
}

model ConciliacaoItem {
  id             Int @id @default(autoincrement())
  conciliacaoId  Int
  conciliacao    Conciliacao @relation(fields: [conciliacaoId], references: [id])

  origem         OrigemConciliacao
  trierId        Int?
  redeId         Int?

  valor          Decimal @db.Decimal(10,2)

  trier          TrierCartaoVendas? @relation(fields: [trierId], references: [id])
  rede           RedeVenda?         @relation(fields: [redeId], references: [id])

  @@index([trierId])
  @@index([redeId])
}

enum OrigemConciliacao {
  TRIER
  REDE
}

enum MetodoConciliacao {
  AUTO
  MANUAL
}


model CronJobETL{
  id Int @default(autoincrement()) @id
  jobName String
  message String
  createdAt DateTime @default(now())
  finishedAt DateTime?
  status StatusJob
  runDate    DateTime  @db.Date
  @@unique([jobName,runDate])
}
model BalanceFisic{
  id Int @default(autoincrement()) @id
  value_100_50 Decimal  @db.Decimal(9,2) @default(0)
  value_20 Decimal  @db.Decimal(9,2) @default(0)
  value_10 Decimal  @db.Decimal(9,2) @default(0)
  value_5 Decimal  @db.Decimal(9,2) @default(0)
  value_2 Decimal  @db.Decimal(9,2) @default(0)
  value_moedas Decimal  @db.Decimal(9,2) @default(0)
  value_reserva Decimal  @db.Decimal(9,2) @default(0)
  filialId Int?
  filial Filial? @relation("FiliaAndBalancyFisic",fields: [filialId],references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model DeletedMovements {
 id         Int      @id @default(autoincrement())
  movementId Int  @unique()
  status     Status   @default(PENDENTE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model excel_staging_diferenca_caixa {
  id               BigInt    @id @default(autoincrement())
  filial           String?   @db.VarChar(50)
  dia              DateTime? @db.Date
  caixa            String?   @db.VarChar(50)
  operador         String?   @db.VarChar(100)
  valor            Decimal?  @db.Decimal(10, 2)
  sobra            Decimal?  @db.Decimal(10, 2)
  falta            Decimal?  @db.Decimal(10, 2)
  obs              String?   @db.Text
  origem_arquivo   String?   @db.VarChar(255)
  imported_at      DateTime? @default(now()) @db.Timestamp(0)
  movimentation_id Int?      @unique(map: "uk_movimentation_id")
}
